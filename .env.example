# Optional: full URL for background audio (HTTPS). If unset, uses 14-days.mp3 from public/.
# VITE_BG_AUDIO_URL=https://your-cdn.example.com/14-days.mp3

# If the site is NOT at the domain root — e.g. GitHub Pages at https://USER.github.io/personal/
# — set this to your repo name with slashes (Vite needs a trailing slash):
# VITE_BASE_PATH=/personal/
#
# Leave unset (or VITE_BASE_PATH=/) for Vercel/Netlify at https://your-domain.com/
